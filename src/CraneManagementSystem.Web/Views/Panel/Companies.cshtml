@model CraneManagementSystem.Web.ViewModels.PagedCompaniesViewModel
@{
    ViewData["Title"] = "Firmalar";
    Layout = "~/Views/Shared/_PanelLayout.cshtml";
}

<h1 class="panel-page-title">Firmalar</h1>

<div class="table-wrapper">
    <table class="table table-modern table-striped mb-0">
        <thead>
            <tr>
                <th>Ad</th>
                <th>Vergi No</th>
                <th>Telefon</th>
                <th>E-posta</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Items?.Any() == true)
            {
                @foreach (var c in Model.Items)
                {
                    <tr>
                        <td>@c.Name</td>
                        <td>@c.TaxNumber</td>
                        <td>@c.Phone</td>
                        <td>@c.Email</td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="4" class="p-0">
                        <div class="empty-state">Kayıt bulunamadı.</div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@{
    var totalPages = Model.PageSize > 0 ? (int)Math.Ceiling((double)Model.TotalCount / Model.PageSize) : 1;
}
@if (totalPages > 1)
{
    <nav class="mt-4" aria-label="Sayfa navigasyonu">
        <ul class="pagination pagination-modern justify-content-center">
            @for (var i = 1; i <= totalPages; i++)
            {
                <li class="page-item @(i == Model.Page ? "active" : "")">
                    <a class="page-link" asp-action="Companies" asp-route-page="@i" asp-route-pageSize="@Model.PageSize">@i</a>
                </li>
            }
        </ul>
    </nav>
}
