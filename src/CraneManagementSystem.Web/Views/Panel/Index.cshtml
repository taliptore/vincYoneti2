@model CraneManagementSystem.Web.ViewModels.DashboardSummaryViewModel
@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Views/Shared/_PanelLayout.cshtml";
}

<h1 class="panel-page-title">Dashboard</h1>

<div class="dashboard-grid mb-5">
    <div class="dashboard-card">
        <div class="dashboard-label">Firmalar</div>
        <div class="dashboard-value">@Model.TotalCompanies</div>
    </div>
    <div class="dashboard-card">
        <div class="dashboard-label">Vinçler</div>
        <div class="dashboard-value">@Model.TotalCranes</div>
    </div>
    <div class="dashboard-card">
        <div class="dashboard-label">Aktif Vinç</div>
        <div class="dashboard-value">@Model.ActiveCranes</div>
    </div>
    <div class="dashboard-card">
        <div class="dashboard-label">Şantiyeler</div>
        <div class="dashboard-value">@Model.TotalConstructionSites</div>
    </div>
    <div class="dashboard-card">
        <div class="dashboard-label">Operatörler</div>
        <div class="dashboard-value">@Model.TotalOperators</div>
    </div>
    <div class="dashboard-card">
        <div class="dashboard-label">Bekleyen Randevu</div>
        <div class="dashboard-value">@Model.PendingAppointments</div>
    </div>
</div>

<div class="row">
    <div class="col-12 col-md-4 mb-4">
        <div class="card card-modern h-100">
            <div class="card-body">
                <div class="card-title">Bu Ay Gelir</div>
                <div class="card-value">@Model.TotalIncomeThisMonth.ToString("N2") ₺</div>
            </div>
        </div>
    </div>
    <div class="col-12 col-md-4 mb-4">
        <div class="card card-modern h-100">
            <div class="card-body">
                <div class="card-title">Bu Ay Gider</div>
                <div class="card-value">@Model.TotalExpenseThisMonth.ToString("N2") ₺</div>
            </div>
        </div>
    </div>
    <div class="col-12 col-md-4 mb-4">
        <div class="card card-modern h-100">
            <div class="card-body">
                <div class="card-title">Okunmamış İletişim</div>
                <div class="card-value">@Model.UnreadContactMessages</div>
            </div>
        </div>
    </div>
</div>
