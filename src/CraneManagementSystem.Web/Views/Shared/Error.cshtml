@model ErrorViewModel
@{
    ViewData["Title"] = "Hata";
}

<div class="error-page">
    <h1>Bir hata oluştu</h1>
    <h2>İsteğiniz işlenirken bir sorun oluştu. Lütfen tekrar deneyin veya ana sayfaya dönün.</h2>
    @if (Model.ShowRequestId)
    {
        <p class="mb-0 text-muted small">
            <strong>İstek no:</strong> <code>@Model.RequestId</code>
        </p>
    }
    <p class="mt-4 mb-0">
        <a asp-controller="Home" asp-action="Index" class="btn btn-primary">Ana sayfaya dön</a>
    </p>
</div>
