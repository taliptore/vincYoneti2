@model CraneManagementSystem.Web.ViewModels.ContactFormViewModel
@{
    ViewData["Title"] = "İletişim";
}

<h1 class="mb-4">İletişim</h1>

<div class="form-card">
    <form asp-action="Contact" method="post">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
        <div class="mb-4">
            <label asp-for="Name" class="form-label"></label>
            <input asp-for="Name" class="form-control" />
            <span asp-validation-for="Name" class="text-danger small"></span>
        </div>
        <div class="mb-4">
            <label asp-for="Email" class="form-label"></label>
            <input asp-for="Email" class="form-control" />
            <span asp-validation-for="Email" class="text-danger small"></span>
        </div>
        <div class="mb-4">
            <label asp-for="Phone" class="form-label"></label>
            <input asp-for="Phone" class="form-control" />
        </div>
        <div class="mb-4">
            <label asp-for="Subject" class="form-label"></label>
            <input asp-for="Subject" class="form-control" />
        </div>
        <div class="mb-4">
            <label asp-for="Message" class="form-label"></label>
            <textarea asp-for="Message" class="form-control" rows="4"></textarea>
        </div>
        <div class="d-flex gap-2 flex-wrap">
            <button type="submit" class="btn btn-primary">Gönder</button>
            <a asp-action="Index" class="btn btn-secondary">İptal</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
